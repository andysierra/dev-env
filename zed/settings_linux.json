// Zed settings — Linux (adaptado desde la config de macOS)
//
// Docs: https://zed.dev/docs/configuring-zed
// Ver defaults: paleta de comandos -> `zed: open default settings`
{
  "agent_buffer_font_size": 12.0,
  "agent_ui_font_size": 17.0,
  "buffer_font_weight": 400.0,
  "agent_servers": {
    "claude-acp": {
      "favorite_config_option_values": {
        "mode": ["bypassPermissions"],
        "model": ["opus[1m]"],
        "effort": ["medium"],
        "fast": ["on"],
      },
      "default_config_options": {
        "mode": "bypassPermissions",
        "effort": "medium",
        "fast": "on",
        "model": "opus[1m]",
      },
      "type": "registry",
    },
  },
  "outline_panel": {
    "default_width": 300.0,
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "soft_wrap": "editor_width",
  "format_on_save": "off",
  "colorize_brackets": true,
  "on_last_window_closed": "quit_app",
  "when_closing_with_no_tabs": "close_window",
  "icon_theme": {
    "mode": "dark",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme",
  },
  "base_keymap": "VSCode",
  "buffer_font_family": "Fira Code",
  "preview_tabs": {
    "enable_preview_from_project_panel": true,
    "enabled": true,
  },
  "indent_guides": {
    "coloring": "indent_aware",
    "background_coloring": "indent_aware",
    "enabled": true,
  },
  "centered_layout": {
    "left_padding": 0.2,
  },
  "tabs": {
    "show_close_button": "always",
    "git_status": true,
  },
  "debugger": {
    "button": false,
  },
  "search": {
    "button": false,
  },
  "bottom_dock_layout": "full",
  "title_bar": {
    "show_menus": false,
    "show_branch_name": true,
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
    "show": false,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "buffer_line_height": "standard",
  "project_panel": {
    "auto_fold_dirs": false,
    "dock": "left",
    "bold_folder_labels": true,
    "hide_hidden": false,
    "hide_root": true,
    "folder_icons": true,
    "file_icons": true,
    "button": true,
    "indent_guides": {
      "show": "always",
    },
    "entry_spacing": "standard",
  },
  "terminal": {
    "copy_on_select": true,
    "button": false,
    // "system" usa tu shell de login (fish/zsh/bash de CachyOS) con todo tu entorno.
    // Si quieres forzar uno: { "program": "/usr/bin/fish" } o "/usr/bin/zsh"
    "shell": "system",
    "font_size": 14.0,
  },
  "ui_font_weight": 550.0,
  "agent": {
    "sidebar_side": "right",
    "single_file_review": true,
    "dock": "right",
    "button": false,
    "favorite_models": [],
    "model_parameters": [],
    "tool_permissions": {
      "tools": {
        "search_web": {
          "default": "allow",
        },
      },
    },
  },
  "restore_on_startup": "empty_tab",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "ui_font_size": 12.0,
  "buffer_font_size": 16.0,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "One Dark",
  },
  "lsp": {
    "jdtls": {
      "binary": {
        // VERIFICA la ruta: `which jdtls` (en macOS era /opt/homebrew/opt/jdtls/bin/jdtls)
        // Si prefieres que Zed autogestione jdtls, borra todo este bloque "jdtls".
        "path": "/usr/bin/jdtls",
      },
    },
    "terraform-ls": {
      "binary": {
        // VERIFICA la ruta: `which terraform-ls`
        "path": "/usr/bin/terraform-ls",
        "arguments": ["serve"],
      },
    },
  },
}
